{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "grocery-resource-addl-props.json",
  "description": "GroceryResource extending RetailResource via allOf — both use additionalProperties: false. PROBLEM: the grocery-level additionalProperties: false has no top-level 'properties', so it rejects ALL instance properties. Even if that were fixed, RetailResource's additionalProperties: false would reject 'nutrition'.",
  "type": "object",
  "additionalProperties": false,
  "allOf": [
    { "$ref": "retail-resource-addl-props.json" },
    {
      "type": "object",
      "properties": {
        "nutrition": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["nutrient", "value"],
            "properties": {
              "nutrient": { "type": "string" },
              "value":    { "$ref": "quantity.json" }
            }
          }
        },
        "freshProduce": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "netQuantityDeclaration": { "type": "string" }
          }
        }
      }
    }
  ]
}
